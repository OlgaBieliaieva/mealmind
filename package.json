{
  "name": "mealmind",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "next": {
      "postcss": "8.5.21",
      "sharp": "0.35.3"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "2.10.5",
    "typescript": "5.9.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.35.3": true
  }
}
